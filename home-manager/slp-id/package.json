  "type": "module",
  "bin": "./dist/index.mjs",
  "scripts": {
    "build:clean": "rimraf dist",
    "build:mk": "tsdown",
    "build:exe": "node -e 'import(`make-executable`).then(me => me.makeExecutable(`./dist/index.mjs`))'",
    "build:dist": "run-s build:clean build:mk build:exe",
    "build": "",
    "start": "tsx -- index.ts"
  },
  "devDependencies": {
    "make-executable": "^2.0.2",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@dz/slp-lib": "github:mitchdzugan/slp-lib"
  }
}
